  "testScenarios": [
    {
      "name": "SCENARIO 1: Création complète - Module → Leçon → Ressources",
      "steps": [
        "1. Récupérez d'abord une formation existante (GET /api/formations)",
        "2. Exécutez #1 (CREATE MODULE) avec le formationId",
        "3. Copiez le module ID du résultat",
        "4. Exécutez #5 (CREATE LESSON) avec le moduleId",
        "5. Copiez le lesson ID du résultat",
        "6. Exécutez #9 (CREATE RESOURCE VIDEO) avec le lessonId",
        "7. Exécutez #10 (CREATE RESOURCE PDF) avec le lessonId",
        "8. Vérifiez avec #11 (GET RESOURCES BY LESSON) - vous devez voir 2 ressources"
      ]
    },
    {
      "name": "SCENARIO 2: Vérification de la hiérarchie complète",
      "steps": [
        "1. Exécutez #2 (GET MODULES BY FORMATION) avec un formationId",
        "2. Prenez le premier moduleId",
        "3. Exécutez #6 (GET LESSONS BY MODULE) avec ce moduleId",
        "4. Prenez le premier lessonId",
        "5. Exécutez #11 (GET RESOURCES BY LESSON) avec ce lessonId",
        "6. Vous devriez voir la hiérarchie: Formation → Modules → Lessons → Resources"
      ]
    },
    {
      "name": "SCENARIO 3: Cascade DELETE",
      "steps": [
        "1. Créez une hiérarchie complète (Scenario 1)",
        "2. Exécutez #16 (DELETE MODULE)",
        "3. Vérifiez que les leçons et ressources ont été supprimées",
        "4. Essayez #7 (GET LESSON BY ID) avec un lesson ID supprimé",
        "5. Vous devriez obtenir une erreur 404"
      ]
    }
  ],
  "setup": {
